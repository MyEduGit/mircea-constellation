# ─────────────────────────────────────────────────────────────────────────────
# NemoClaw Observer — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── VPS (Hetzy / 46.225.51.30) ───────────────────────────────────────────────
VPS_HOST=46.225.51.30
N8N_PORT=5678
PG_HOST=46.225.51.30
PG_PORT=5432
PG_DSN=postgresql://postgres:YOUR_PG_PASSWORD@46.225.51.30:5432/amep_schema_v1
REDIS_HOST=46.225.51.30
REDIS_PORT=6379
QDRANT_HOST=46.225.51.30
QDRANT_PORT=6333

# ── Local (iMac M4 / NemoClaw) ───────────────────────────────────────────────
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# ── Telegram ─────────────────────────────────────────────────────────────────
# hetzy_phd.py bot token + chat ID of the operator
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT=YOUR_CHAT_ID_HERE

# ── Z.ai spend tracking ───────────────────────────────────────────────────────
# Update ZAI_SPEND_THIS_MONTH at each Z.ai invoice / n8n billing-check workflow
# Alert fires at 80% of cap ($4.00).  HALT fires at 100% ($5.00).
ZAI_SPEND_THIS_MONTH=0.00
ZAI_MONTHLY_CAP=5.00

# ── Alert thresholds ─────────────────────────────────────────────────────────
# Flag any agent that has not reported in more than this many hours
AGENT_IDLE_HOURS=24
