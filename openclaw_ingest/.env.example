# openclaw_ingest/.env — generated by setup/openclaw_ingest_install.sh
# Copy to .env (or let the install script create it) and edit as needed.
# Never commit the real .env (it's host-specific).

# UID/GID of the host user running Docker. Must match ownership of the
# bind-mounted host dirs so the container can read/write them.
HOST_UID=1000
HOST_GID=1000

# Cognee dataset name (configurable; do not hardcode in code).
# One unified corpus with a 'source' tag per the Great Ingestion direction.
DATASET_NAME=mircea_corpus

# Logging
LOG_LEVEL=INFO
