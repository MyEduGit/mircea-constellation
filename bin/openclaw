#!/usr/bin/env bash
# openclaw — ergonomic CLI for OpenClaw (Hetzner 46.225.51.30, user: mircea)
# UrantiOS governed — Truth, Beauty, Goodness
#
# Install (on iMac):
#   ln -sf "$(pwd)/bin/openclaw" /usr/local/bin/openclaw
#   # requires the 'hetzner-urantios' SSH host entry
#   # (created by setup/m1_terminal.sh in phd-triune-monism)
#
# Usage:
#   openclaw help
#   openclaw dash                  # open dashboard in browser
#   openclaw status                # curl status.json, pretty-printed
#   openclaw ssh [cmd...]          # interactive shell, or run a remote cmd
#   openclaw run <cmd>             # alias for `ssh <cmd>`
#   openclaw ps                    # systemd units + listening ports on OpenClaw
#   openclaw logs <unit> [-n N]    # journalctl -u <unit> -f (or -n N)
#   openclaw deploy <repo>         # pull & run setup/openclaw_server.sh for a repo
#   openclaw soul                  # tail the unified prompt
#   openclaw probe                 # health check (ports 18789/18791/18792)

set -euo pipefail

HOST="${OPENCLAW_HOST:-hetzner-urantios}"
IP="46.225.51.30"
DASH_URL="http://${IP}:18789/"
STATUS_URL="http://${IP}:18789/status.json"

CYAN='\033[0;36m'; GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'; NC='\033[0m'
info(){ echo -e "${CYAN}[openclaw]${NC} $*" >&2; }
ok()  { echo -e "${GREEN}[ok]${NC} $*" >&2; }
warn(){ echo -e "${YELLOW}[warn]${NC} $*" >&2; }
die() { echo -e "${RED}[err]${NC} $*" >&2; exit 1; }

rssh() { ssh -o BatchMode=no "${HOST}" "$@"; }

cmd_help() {
  sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
}

cmd_dash() {
  info "opening ${DASH_URL}"
  if command -v open >/dev/null; then open "${DASH_URL}";
  elif command -v xdg-open >/dev/null; then xdg-open "${DASH_URL}";
  else echo "${DASH_URL}"; fi
}

cmd_status() {
  if command -v jq >/dev/null; then
    curl -fsS --max-time 5 "${STATUS_URL}" | jq .
  else
    curl -fsS --max-time 5 "${STATUS_URL}"
  fi
}

cmd_probe() {
  info "probing ${IP} …"
  for port in 18789 18791 18792 22; do
    if (timeout 3 bash -c ">/dev/tcp/${IP}/${port}") 2>/dev/null; then
      ok "tcp/${port} open"
    else
      warn "tcp/${port} closed/filtered"
    fi
  done
}

cmd_ssh() {
  if [ "$#" -eq 0 ]; then rssh; else rssh "$@"; fi
}

cmd_run() {
  [ "$#" -gt 0 ] || die "usage: openclaw run <command>"
  rssh "$@"
}

cmd_ps() {
  rssh 'echo "── active UrantiOS/OpenClaw units ──"; \
        systemctl list-units --type=service --state=running \
          | grep -Ei "lobster|urant|gabriel|nanoclaw|openclaw|cognee|ollama" || echo "(none matched)"; \
        echo; echo "── listening ports ──"; \
        ss -tlnp 2>/dev/null || sudo ss -tlnp'
}

cmd_logs() {
  [ "$#" -ge 1 ] || die "usage: openclaw logs <unit> [-n N]"
  local unit="$1"; shift
  if [ "$#" -gt 0 ]; then
    rssh "journalctl -u '${unit}' $*"
  else
    rssh -t "journalctl -u '${unit}' -f"
  fi
}

cmd_deploy() {
  [ "$#" -eq 1 ] || die "usage: openclaw deploy <repo>  (e.g. urantios, phd-triune-monism, lobsterbot, mircea-constellation)"
  local repo="$1"
  info "deploying ${repo} on ${HOST}…"
  rssh "set -e; \
    cd \$HOME; \
    if [ -d ${repo}/.git ]; then git -C ${repo} pull --ff-only; \
    else git clone https://github.com/myedugit/${repo}.git; fi; \
    bash ${repo}/setup/openclaw_server.sh"
}

cmd_soul() {
  rssh 'cat ~/.openclaw/unified-prompt.md 2>/dev/null \
        || echo "(no unified-prompt.md — run: openclaw deploy phd-triune-monism)"'
}

main() {
  local sub="${1:-help}"; shift || true
  case "${sub}" in
    help|-h|--help) cmd_help "$@" ;;
    dash)           cmd_dash "$@" ;;
    status)         cmd_status "$@" ;;
    probe)          cmd_probe "$@" ;;
    ssh)            cmd_ssh "$@" ;;
    run)            cmd_run "$@" ;;
    ps)             cmd_ps "$@" ;;
    logs)           cmd_logs "$@" ;;
    deploy)         cmd_deploy "$@" ;;
    soul)           cmd_soul "$@" ;;
    *) die "unknown subcommand: ${sub} (try: openclaw help)" ;;
  esac
}

main "$@"
